# .env.example — safe to commit; contains no real credentials.
# Copy to .env and fill in your actual values before running the project.

# Environment: "production" silences all errors to browser, "development" shows them
APP_ENV=production

DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password
DB_CHARSET=utf8mb4

# Error log path. Relative paths are resolved from the project root.
LOG_PATH=logs/php_errors.log

# ── PayPal ────────────────────────────────────────────────────────────────────
# Get your credentials at https://developer.paypal.com/dashboard/applications
# sandbox = testing; live = real money
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_CURRENCY=USD

# ── Mailer (PHPMailer / SMTP) ─────────────────────────────────────────────────
# Run "composer install" once to install PHPMailer before enabling mail.
#
# Gmail: use an App Password (not your normal password).
#   Settings → Security → 2-Step Verification → App passwords
#   MAIL_HOST=smtp.gmail.com | MAIL_PORT=587 | MAIL_ENCRYPTION=tls
#
# Outlook / Hotmail:
#   MAIL_HOST=smtp-mail.outlook.com | MAIL_PORT=587 | MAIL_ENCRYPTION=tls
#
# Free transactional services (recommended for production):
#   Brevo (Sendinblue) – https://app.brevo.com/settings/keys/smtp
#   Mailgun            – https://app.mailgun.com/app/sending/domains
#   SendGrid           – https://app.sendgrid.com/settings/api_keys
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=GymSupps Store
# The address that receives admin "new order" alerts
MAIL_ADMIN_TO=admin@example.com

# ── WhatsApp ──────────────────────────────────────────────────────────────────
# International format, digits only — no +, spaces, or dashes.
# Lebanon example: +961 71 234 567 → 96171234567
WHATSAPP_NUMBER=96100000000
